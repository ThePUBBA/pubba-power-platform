# Comma-separated browser origins allowed to call the API. Keep the Retool
# origin when Retool remains in use. Never use * with credentialed CORS.
ALLOWED_ORIGINS=https://pubbapower.com,https://www.pubbapower.com,https://app.pubbapower.com,https://your-org.retool.com

# Required production ledger configuration. Keep the service-role key secret.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Preferred dashboard-to-API configuration. Use http://localhost:8000 locally.
PUBBA_POWER_API_BASE_URL=http://localhost:8000
# Legacy compatibility fallback; existing deployments may continue using it.
ONLY1_API_BASE_URL=http://localhost:8000

# Telemetry writes are disabled by default. Enable only for an authenticated
# ingestion environment and set a secret token supplied as X-Telemetry-Key.
TELEMETRY_WRITES_ENABLED=false
TELEMETRY_WRITE_TOKEN=
TELEMETRY_MAX_BATCH_SIZE=100

# Central freshness thresholds and optional expected source names.
TELEMETRY_FRESH_SECONDS=300
TELEMETRY_DELAYED_SECONDS=900
TELEMETRY_STALE_SECONDS=3600
TELEMETRY_CHART_GAP_SECONDS=1800
TELEMETRY_CONFIGURED_SOURCES=

# Populate only after a real source and its identifiers are verified. Keep this value
# in the deployment secret manager rather than source control.
TELEMETRY_ASSET_MAPPINGS_JSON=

# Development/test-only simulated telemetry generator. Never enable in production.
PUBBA_ENABLE_SIMULATED_TELEMETRY=false

# Advisory recommendation assumptions. These are planning inputs, not telemetry.
RECOMMENDATION_ROUND_TRIP_EFFICIENCY=0.80
RECOMMENDATION_VARIABLE_OM_PER_MWH=0
RECOMMENDATION_MARKET_STALE_SECONDS=1200

# Explicit recommendation audit writes. Keep disabled until the additive history
# migration is manually applied and an operator credential is securely configured.
RECOMMENDATION_WRITES_ENABLED=false
RECOMMENDATION_WRITE_TOKEN=
RECOMMENDATION_CAPTURE_DEDUP_SECONDS=300
