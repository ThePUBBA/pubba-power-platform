# Comma-separated browser origins allowed to call the API.
# Set this to the exact Retool app or custom-domain origins used by Only1 Power.
ALLOWED_ORIGINS=https://your-org.retool.com

# Optional Airtable archive for successful POST /simulate requests.
# Use an Airtable personal access token with record write access.
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
# Legacy fallback for AIRTABLE_SIMULATIONS_TABLE.
AIRTABLE_TABLE_NAME=
AIRTABLE_SIMULATIONS_TABLE=Simulation Results
AIRTABLE_ASSETS_TABLE=Assets
AIRTABLE_DISPATCH_EVENTS_TABLE=Dispatch Events
AIRTABLE_DAILY_PNL_TABLE=Daily P&L
