# Comma-separated browser origins allowed to call the API. Keep the Retool
# origin when Retool remains in use. Never use * with credentialed CORS.
ALLOWED_ORIGINS=https://pubbapower.com,https://www.pubbapower.com,https://app.pubbapower.com,https://your-org.retool.com

# Required production ledger configuration. Keep the service-role key secret.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Preferred dashboard-to-API configuration. Use http://localhost:8000 locally.
PUBBA_POWER_API_BASE_URL=http://localhost:8000
# Legacy compatibility fallback; existing deployments may continue using it.
ONLY1_API_BASE_URL=http://localhost:8000

# Telemetry writes are disabled by default. Enable only for an authenticated
# ingestion environment and set a secret token supplied as X-Telemetry-Key.
TELEMETRY_WRITES_ENABLED=false
TELEMETRY_WRITE_TOKEN=

# Development/test-only simulated telemetry generator. Never enable in production.
PUBBA_ENABLE_SIMULATED_TELEMETRY=false
